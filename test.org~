import numpy as np
import matplotlib.pyplot as plt

def cursive_q(t):
    """Parametric curve for cursive 'q'"""
    # Circle part of q
    x1 = 0.3 * np.cos(t * 2 * np.pi)
    y1 = 0.3 * np.sin(t * 2 * np.pi) + 0.3
    
    # Descender stroke
    t_desc = t - 0.75
    x2 = 0.3 + t_desc * 0.2
    y2 = 0.3 - t_desc * 1.2
    
    # Blend between circle and descender
    blend = np.where(t < 0.75, 1, 0)
    x = blend * x1 + (1 - blend) * x2
    y = blend * y1 + (1 - blend) * y2
    return x, y

def cursive_u(t, offset_x=0):
    """Parametric curve for cursive 'u'"""
    x = offset_x + t * 0.6
    y = 0.3 * (np.sin(t * np.pi) ** 2)
    return x, y

def cursive_i(t, offset_x=0):
    """Parametric curve for cursive 'i'"""
    x = offset_x + t * 0.1
    y = t * 0.6
    return x, y

def cursive_p(t, offset_x=0):
    """Parametric curve for cursive 'p'"""
    # Circle part
    x1 = offset_x + 0.3 * np.cos(t * 2 * np.pi) + 0.3
    y1 = 0.3 * np.sin(t * 2 * np.pi) + 0.3
    
    # Descender
    t_desc = t - 0.75
    x2 = offset_x
    y2 = 0.6 - t_desc * 1.2
    
    blend = np.where(t < 0.75, 1, 0)
    x = blend * x1 + (1 - blend) * x2
    y = blend * y1 + (1 - blend) * y2
    return x, y

def cursive_s(t, offset_x=0):
    """Parametric curve for cursive 's'"""
    x = offset_x + t * 0.5
    y = 0.3 + 0.25 * np.sin(t * 4 * np.pi)
    return x, y

# Create the full word
t = np.linspace(0, 1, 200)

fig, ax = plt.subplots(figsize=(14, 4))

# Draw each letter with appropriate spacing
x_q, y_q = cursive_q(t)
ax.plot(x_q, y_q, 'b-', linewidth=2.5)

x_u, y_u = cursive_u(t, offset_x=0.6)
ax.plot(x_u, y_u, 'b-', linewidth=2.5)

x_i1, y_i1 = cursive_i(t, offset_x=1.3)
ax.plot(x_i1, y_i1, 'b-', linewidth=2.5)
# Dot for i
ax.plot([1.35], [0.8], 'bo', markersize=4)

x_p, y_p = cursive_p(t, offset_x=1.6)
ax.plot(x_p, y_p, 'b-', linewidth=2.5)

x_u2, y_u2 = cursive_u(t, offset_x=2.3)
ax.plot(x_u2, y_u2, 'b-', linewidth=2.5)

x_s, y_s = cursive_s(t, offset_x=3.0)
ax.plot(x_s, y_s, 'b-', linewidth=2.5)

ax.set_aspect('equal')
ax.grid(True, alpha=0.3)
ax.set_title('Parametric Curve: "quipus" in Cursive', fontsize=16)
ax.set_xlabel('x')
ax.set_ylabel('y')

plt.tight_layout()
plt.savefig('/mnt/user-data/outputs/quipus_cursive.png', dpi=150, bbox_inches='tight')
plt.show()

print("Cursive 'quipus' created using parametric curves!")
